# ───────────────────────────────────────────────────────────
#  Streamlit Cloud 배포용 secrets 템플릿 (TOML)
#  ⚠️ 이 .example 파일엔 실제 값을 넣지 말 것. 실제 secrets는
#     Streamlit Cloud → App settings → Secrets 에 붙여넣는다(파일 커밋 금지).
#     로컬 테스트 시엔 이 내용을 .streamlit/secrets.toml 로 복사해 채운다(gitignore됨).
# ───────────────────────────────────────────────────────────

# ── 접근 비밀번호 (선택) ──
# 값을 넣으면 앱이 비번을 요구(학회원만 접근). 비우거나 빼면 게이트 비활성(누구나 접근).
app_password = "여기에-공유할-접근-비밀번호"

# ── LLM API 키 (사용할 모델만 채움) ──
GOOGLE_API_KEY = ""        # Gemini (검증에 사용한 모델)
ANTHROPIC_API_KEY = ""     # Claude (선택)
OPENAI_API_KEY = ""        # GPT (선택)

# ── (선택) Drive 평가지표 폴더 / 이력 시트 ID ──
# 코드에 기본값이 있어 보통 생략 가능. 다른 폴더/시트를 쓸 때만 지정.
# DRIVE_INDICATORS_FOLDER_ID = "1-pErqxOsqGcY5D9S_IHq3f_WXMgywTLo"
# GSHEET_SPREADSHEET_ID = "1TDL5f0W6lkOKtE9Mjmf6al_m9w9GziNpkwYiLy-bHP4"

# ── Google 서비스계정 (Drive 평가지표 로드 + 이력 시트 기록) ──
# credentials/gsheet_service_account.json 의 각 필드를 그대로 옮긴다.
# private_key 는 줄바꿈을 \n 으로 둔 한 줄 문자열(아래 형식)로 넣는다.
[gsheet]
type = "service_account"
project_id = "kase-ai-analyzer"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...여러 줄...\n-----END PRIVATE KEY-----\n"
client_email = "kase-esg-analyzer@kase-ai-analyzer.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
