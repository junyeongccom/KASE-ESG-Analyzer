# ── KASE ESG 자동 분석 시스템 API 키 설정 ──
# 이 파일을 .env로 복사한 뒤 사용할 모델의 API 키를 입력하세요.
# 사용하지 않는 모델은 비워두면 됩니다.

# Anthropic Claude API
ANTHROPIC_API_KEY=

# OpenAI GPT API
OPENAI_API_KEY=

# Google Gemini API
GOOGLE_API_KEY=

# ── Google Sheets 이력 저장 설정 ──
# 서비스 계정 JSON 파일 경로 (기본: credentials/gsheet_service_account.json)
# GSHEET_CREDENTIALS_FILE=credentials/gsheet_service_account.json
# 스프레드시트 이름 (기본: KASE ESG 분석 이력)
# GSHEET_SPREADSHEET_NAME=KASE ESG 분석 이력
# 이력을 쌓을 스프레드시트 ID(권장). 시트 URL `.../spreadsheets/d/<여기>/edit` 부분.
# 설정하면 이름 대신 이 시트를 직접 연다. 서비스계정 이메일에 '편집자'로 공유 필요.
# GSHEET_SPREADSHEET_ID=

# ── Google Drive 평가지표 동기화 설정 ──
# 산업별 하위폴더(식품/, 건설/ …)를 담은 "평가지표" 폴더의 ID.
# Drive에서 그 폴더를 열었을 때 URL `.../folders/<여기>` 부분. 비우면 동기화를 건너뛴다.
# 그 폴더(또는 상위 폴더)를 서비스계정 이메일에 '뷰어'로 공유해야 앱이 읽을 수 있다.
# DRIVE_INDICATORS_FOLDER_ID=
